{
  "name": "visualizerstudio",
  "version": "1.0.0",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "npm run build && electron-builder",
    "package": "npm run build && electron-packager . \"Visualizer Studio\" --platform=win32 --arch=x64 --out=dist_output --overwrite --icon=public/favicon.ico",
    "package-all": "npm run build && electron-packager . \"Visualizer Studio\" --platform=win32,darwin --arch=x64 --out=dist_global --overwrite --icon=public/favicon.ico"
  },
  "build": {
    "appId": "com.visualizer.studio",
    "productName": "Visualizer Studio",
    "directories": {
      "output": "dist_pc"
    },
    "files": [
      "dist_web/**/*",
      "main.cjs"
    ],
    "win": {
      "target": [
        "dir"
      ],
      "icon": "public/favicon.ico"
    },
    "publish": null
  },
  "dependencies": {
    "canvas-confetti": "^1.6.0",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.4"
  }
}
